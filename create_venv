#!/usr/bin/env bash

set -euo pipefail

rm -rf venv
python3 -m venv venv
printf '. venv/bin/activate\n' > v

requirements_file="requirements.txt"
if [[ ! -f "${requirements_file}" && -f "requirments.txt" ]]; then
    requirements_file="requirments.txt"
fi

if [[ ! -f "${requirements_file}" ]]; then
    echo "No requirements file found." >&2
    exit 1
fi

./venv/bin/python -m pip install --upgrade pip setuptools wheel
./venv/bin/python -m pip install -r "${requirements_file}"

./venv/bin/python - <<'PY'
import importlib
import sys
from typing import List, Optional

try:
    from zoneinfo import ZoneInfo
except ImportError:
    from backports.zoneinfo import ZoneInfo


def check_import(module_name: str) -> Optional[str]:
    try:
        importlib.import_module(module_name)
    except Exception as exc:
        return f"{module_name}: {exc}"
    return None


if sys.version_info < (3, 8):
    print("Python 3.8 or newer is required.", file=sys.stderr)
    sys.exit(1)


errors: List[str] = []
for module_name in ("yaml", "requests", "PIL", "pygame", "bidi", "tkinter"):
    error = check_import(module_name)
    if error is not None:
        errors.append(error)

try:
    ZoneInfo("Asia/Jerusalem")
except Exception as exc:
    errors.append(f"zoneinfo Asia/Jerusalem: {exc}")

if errors:
    print("Dependency check failed after creating the virtual environment.", file=sys.stderr)
    for error in errors:
        print(f"  - {error}", file=sys.stderr)
    if any(error.startswith("tkinter:") for error in errors):
        print(
            "tkinter must usually be installed by the OS package manager "
            "(for example: python3-tk on Debian/Ubuntu).",
            file=sys.stderr,
        )
    sys.exit(1)

print("Virtual environment is ready.")
PY
