#!/usr/bin/env python3

from __future__ import annotations

import os
from datetime import datetime, timedelta
from pathlib import Path
from time import monotonic

import yaml

import utils
from alert_blink import AlertBlinkManager
from alert_audio import AudioAlertPlayer
from alert_focus_circle import AlertFocusCircleManager
from alert_expiry import AlertExpiryManager
from alert_fetcher import AlertFetcher
from alert_history import AlertHistoryClient
from alert_model import current_oref_time, decode_alert_text, normalize_live_alert, parse_live_alert_text
from alert_render import AlertMarkerRegistry, draw_alert, is_event_ended_alert, persist_alert_artifacts
from israel_map import IsraelMap
from utils import log
from watchdog import WatchdogMonitor


TEST = False
REQUEST_TIMEOUT = (3.05, 5)
POLL_INTERVAL_SECONDS = 10
NOTIFICATION_COOLDOWN_SECONDS = 10
MAX_KNOWN_ALERTS = 2000
SMALL_ALERT_FOCUS_CIRCLE_LIMIT = 6
URL_ALERTS = os.environ.get(
    "OREF_ALERTS_URL",
    "https://www.oref.org.il/warningMessages/alert/Alerts.json",
)
URL_HISTORY = os.environ.get(
    "OREF_ALERTS_HISTORY_URL",
    "https://www.oref.org.il/warningMessages/alert/History/AlertsHistory.json",
)
TEST_ALERT_PATH = "last_alert.yaml"

BASE_DIR = Path(__file__).resolve().parent
ALERT_SOUND_PATH = BASE_DIR / "ocean_4s.mp3"


def remember_alert(alert_key: str, known_order: list[str], known_lookup: set[str]) -> None:
    # 1. Keep both an ordered list and a set so dedup stays fast without growing forever.
    # 2. The ordered list makes it easy to evict the oldest remembered alerts.
    if alert_key in known_lookup:
        return
    known_order.append(alert_key)
    known_lookup.add(alert_key)
    while len(known_order) > MAX_KNOWN_ALERTS:
        oldest_key = known_order.pop(0)
        known_lookup.discard(oldest_key)


def load_test_alert() -> tuple[object | None, str]:
    # 1. TEST mode loads one local alert file and reuses the normal live-alert
    #    normalization path so the rest of the loop behaves the same.
    # 2. Returning both the normalized alert and the raw text keeps the caller logic simple.
    with (BASE_DIR / TEST_ALERT_PATH).open(encoding="utf-8") as handle:
        raw_alert = yaml.safe_load(handle)
    return normalize_live_alert(raw_alert), str(raw_alert)


def describe_notification_trigger(alert, alert_source: str) -> str:
    # 1. Keep the focus-change reason concise but specific enough that the log
    #    can tell which alert path caused a raise-to-front event.
    # 2. Include the title plus a short locality sample because that is usually
    #    the fastest way for the operator to recognize the triggering alert.
    source_label = {
        "live": "live alert",
        "recovery_replay": "recovery replay",
        "test": "test alert",
    }.get(alert_source, alert_source)
    locality_preview = ", ".join(alert.data[:2])
    if len(alert.data) > 2:
        locality_preview += ", ..."
    if locality_preview:
        return f"{source_label}: {alert.title} [{locality_preview}]"
    return f"{source_label}: {alert.title}"


def summarize_notification_triggers(trigger_descriptions: list[str]) -> str:
    # 1. Bound the log message length so a burst of many distinct alerts does
    #    not create an unreadably long focus-change reason.
    # 2. Preserve the first few triggers verbatim because they are usually the
    #    most useful clues while investigating an unexpected raise-to-front.
    if not trigger_descriptions:
        return "unknown alert trigger"
    if len(trigger_descriptions) <= 3:
        return "; ".join(trigger_descriptions)
    displayed = "; ".join(trigger_descriptions[:3])
    remainder = len(trigger_descriptions) - 3
    return f"{displayed}; +{remainder} more"


def fetch_replay_alerts(
    history_client: AlertHistoryClient,
    *,
    startup_replay_done: bool,
    network_was_down: bool,
    last_live_success_at: datetime | None,
    now: datetime,
    startup_replay_seconds: int,
) -> tuple[list[object], bool, str | None]:
    # 1. Startup replay asks for the configured launch window once, after the
    #    first successful contact with the live endpoint.
    # 2. Recovery replay asks only for alerts newer than the last known live success.
    if not startup_replay_done:
        replay_label = "startup"
        replay_since = now - timedelta(seconds=startup_replay_seconds)
    elif network_was_down and last_live_success_at is not None:
        replay_label = "recovery"
        replay_since = last_live_success_at
    else:
        return [], startup_replay_done, None

    try:
        replay_alerts = history_client.fetch_since(replay_since)
    except Exception as exc:
        log(f"Error: could not fetch {replay_label} history ({exc.__class__.__name__}: {exc})")
        return [], True, replay_label

    if replay_alerts:
        log(f"Replaying {len(replay_alerts)} history alerts from {replay_label}")
    return replay_alerts, True, replay_label


def handle_alert(
    alert,
    *,
    alert_text: str,
    base_dir: Path,
    biggest_alert_size: int,
    coords: dict[str, dict[str, float]],
    known_order: list[str],
    known_lookup: set[str],
    map_view: IsraelMap,
    expiry_manager: AlertExpiryManager,
    marker_registry: AlertMarkerRegistry,
) -> tuple[int, list[int], list[tuple[float, float]]]:
    # 1. Skip alerts that were already processed, whether they came from live polling
    #    or from the history replay path.
    # 2. Return only the newly added or state-changed marker ids for blinking,
    #    while still drawing the full alert batch and preserving expiry logic.
    if alert.key in known_lookup:
        return biggest_alert_size, [], []

    biggest_alert_size = persist_alert_artifacts(
        alert,
        base_dir=base_dir,
        biggest_alert_size=biggest_alert_size,
    )
    log("Alert contents:" + str(alert.raw))
    remember_alert(alert.key, known_order, known_lookup)
    try:
        a = yaml.safe_load(alert_text)
        print()
        print(a["title"])
        print("  ", ", ".join(a["data"]))
        print()
    except:
        pass
    draw_result = draw_alert(map_view, coords, alert, log, marker_registry)
    expiry_manager.remember_drawn_alert(alert, draw_result.marker_ids)
    return biggest_alert_size, draw_result.changed_marker_ids, draw_result.resolved_points


def main() -> None:
    coords = utils.get_coords()
    map_view = IsraelMap(auto_refresh=False, show_controls=True)
    audio_player = AudioAlertPlayer(ALERT_SOUND_PATH, log_fn=log)
    if map_view.audible_alert_enabled():
        audio_player.warm_up()
    utils.set_log_time_sink(map_view.set_log_timestamp)

    # 1. Keep the runtime state close to the top-level loop so the main control
    #    flow remains easy to read.
    # 2. `startup_replay_done` and `network_was_down` are the two switches that
    #    decide whether the history helper needs to run.
    known_order: list[str] = []
    known_lookup: set[str] = set()
    history_client = AlertHistoryClient(URL_HISTORY, REQUEST_TIMEOUT)
    blink_manager = AlertBlinkManager()
    focus_circle_manager = AlertFocusCircleManager()
    expiry_manager = AlertExpiryManager()
    marker_registry = AlertMarkerRegistry()
    watchdog = WatchdogMonitor(
        poll_interval_seconds=POLL_INTERVAL_SECONDS,
        request_timeout=REQUEST_TIMEOUT,
    )
    fetcher: AlertFetcher | None = None
    startup_replay_done = TEST
    network_was_down = False
    last_live_success_at: datetime | None = None
    last_watchdog_state: tuple[str, str] | None = None
    last_operator_notification_at: float | None = None
    last_reset_generation = map_view.reset_generation()

    biggest_alert_size = 0
    biggest_alert_path = BASE_DIR / "biggest_alert.yaml"
    if biggest_alert_path.is_file():
        biggest_alert_size = biggest_alert_path.stat().st_size

    if TEST:
        log("TEST MODE ON")
    else:
        # 3. Start the continuous live polling in the background worker.
        fetcher = AlertFetcher(
            url=URL_ALERTS,
            poll_interval=POLL_INTERVAL_SECONDS,
            timeout=REQUEST_TIMEOUT,
            watchdog=watchdog,
        )
        fetcher.start()

    try:
        def update_attention_effects() -> None:
            # 1. Keep the blink and focus-circle duration synchronized because
            #    both are controlled by the same Settings entry.
            # 2. Clearing disabled effects immediately prevents hidden markers
            #    or stale circles from lingering after the operator opts out.
            attention_duration_seconds = map_view.attention_duration_seconds()
            blink_manager.set_duration(attention_duration_seconds)
            focus_circle_manager.set_duration(attention_duration_seconds)
            if map_view.blink_on_appearing_enabled():
                blink_manager.update(map_view)
            else:
                blink_manager.clear(map_view)
            if map_view.small_alert_focus_circle_enabled():
                focus_circle_manager.update(map_view)
            else:
                focus_circle_manager.clear(map_view)

        while map_view.is_open():
            current_reset_generation = map_view.reset_generation()
            if current_reset_generation != last_reset_generation:
                # 1. `Edit -> Clear` wipes the canvas immediately, but the main
                #    loop also has to forget known alert ids and locality state
                #    so the next live poll can repopulate and re-zoom correctly.
                # 2. Clear the transient managers too so they do not keep stale
                #    marker ids or pending circles from the pre-clear map state.
                known_order.clear()
                known_lookup.clear()
                marker_registry.clear()
                expiry_manager.clear()
                blink_manager.clear(map_view)
                focus_circle_manager.clear(map_view)
                last_reset_generation = current_reset_generation
                log("Map cleared: runtime alert state reset")

            watchdog.note_ui_heartbeat()
            watchdog_snapshot = watchdog.snapshot()
            watchdog_state = (watchdog_snapshot.level, watchdog_snapshot.reason_code)
            if watchdog_state != last_watchdog_state:
                if watchdog_snapshot.level == "online":
                    log(f"Watchdog changed state: Online ({watchdog_snapshot.reason_text})")
                else:
                    log(f"Watchdog changed state: Offline ({watchdog_snapshot.reason_text})")
                last_watchdog_state = watchdog_state
            map_view.set_watchdog_status(
                watchdog_snapshot.text,
                level=watchdog_snapshot.level,
                pulse_on=watchdog_snapshot.pulse_on,
            )
            # 3. Let time-based cleanup run continuously, even while the app is idle
            #    or the network is temporarily unavailable.
            update_attention_effects()
            expiry_manager.expire_due_markers(map_view, log_fn=log)
            alerts_to_process: list[tuple[object, str, str]] = []

            if TEST:
                watchdog.note_fetch_attempt()
                test_alert, alert_text = load_test_alert()
                watchdog.note_fetch_success()
                watchdog.note_pipeline_update()
                utils.show_status(watchdog.snapshot().text)
                if test_alert is not None:
                    alerts_to_process.append((test_alert, alert_text, "test"))
            else:
                # 4. Poll the worker thread and keep the UI responsive while we wait.
                fetch_result = fetcher.poll()
                if fetch_result is None:
                    if not utils.sleep_with_ui(
                        map_view,
                        0.1,
                        on_tick=update_attention_effects,
                    ):
                        break
                    continue
                watchdog.note_pipeline_update()
                if fetch_result.error_type is not None:
                    watchdog.note_fetch_failure(
                        f"{fetch_result.error_type}: {fetch_result.error_message}"
                    )
                    network_was_down = True
                    log(
                        "Error: could not fetch data "
                        f"({fetch_result.error_type}: {fetch_result.error_message})"
                    )
                    continue
                if fetch_result.status_code != 200:
                    watchdog.note_fetch_failure(f"HTTP {fetch_result.status_code}")
                    network_was_down = True
                    log(f"Error: Wrong response code: {fetch_result.status_code}")
                    continue

                watchdog.note_fetch_success()
                utils.show_status(watchdog.snapshot().text)
                # 5. Compute replay cutoffs on the explicit OREF timezone basis so
                #    startup and recovery work correctly on machines outside Israel.
                now = current_oref_time()
                alert_text = decode_alert_text(fetch_result.content or b"")
                replay_alerts, startup_replay_done, replay_label = fetch_replay_alerts(
                    history_client,
                    startup_replay_done=startup_replay_done,
                    network_was_down=network_was_down,
                    last_live_success_at=last_live_success_at,
                    now=now,
                    startup_replay_seconds=map_view.startup_history_replay_seconds(),
                )
                network_was_down = False
                last_live_success_at = now

                for replay_alert in replay_alerts:
                    replay_text = str(replay_alert.raw)
                    replay_source = "startup_replay" if replay_label == "startup" else "recovery_replay"
                    alerts_to_process.append((replay_alert, replay_text, replay_source))

                try:
                    live_alert = parse_live_alert_text(alert_text)
                except Exception:
                    log("Error: could not parse data (json load failed)")
                    log("Problem msg:")
                    log(alert_text)
                    continue
                if live_alert is not None:
                    log("Alert fetched")
                    alerts_to_process.append((live_alert, alert_text, "live"))

            should_notify_operator = False
            should_reassess_zoom = False
            pending_focus_circle_points: list[list[tuple[float, float]]] = []
            notification_trigger_descriptions: list[str] = []
            for alert, alert_text, alert_source in alerts_to_process:
                is_new_alert = alert.key not in known_lookup
                biggest_alert_size, blink_marker_ids, resolved_points = handle_alert(
                    alert,
                    alert_text=alert_text,
                    base_dir=BASE_DIR,
                    biggest_alert_size=biggest_alert_size,
                    coords=coords,
                    known_order=known_order,
                    known_lookup=known_lookup,
                    map_view=map_view,
                    expiry_manager=expiry_manager,
                    marker_registry=marker_registry,
                )
                if (
                    map_view.blink_on_appearing_enabled()
                    and is_new_alert
                    and alert_source != "startup_replay"
                ):
                    blink_manager.remember_markers(blink_marker_ids)
                if (
                    map_view.small_alert_focus_circle_enabled()
                    and is_new_alert
                    and alert_source != "startup_replay"
                    and len(alert.data) <= SMALL_ALERT_FOCUS_CIRCLE_LIMIT
                    and resolved_points
                ):
                    pending_focus_circle_points.append(resolved_points)
                if is_new_alert and alert_source != "startup_replay":
                    should_notify_operator = True
                    notification_trigger_descriptions.append(
                        describe_notification_trigger(alert, alert_source)
                    )
                if is_new_alert and not is_event_ended_alert(alert):
                    should_reassess_zoom = True

            if should_reassess_zoom:
                map_view.refresh_localized_zoom()
            if pending_focus_circle_points:
                for focus_circle_points in pending_focus_circle_points:
                    focus_circle_manager.remember_points(map_view, focus_circle_points)

            if should_notify_operator:
                # 1. Startup replay is intentionally excluded so the window does
                #    not steal focus or play sound on launch just because old
                #    history rows were recovered.
                # 2. Live alerts, recovery replays, and explicit end-of-event
                #    alerts all count as real runtime notifications.
                # 3. Apply one shared cooldown across focus-jump and audio so a
                #    burst of alerts cannot overload the operator every second.
                focus_enabled = map_view.focus_on_alert_enabled()
                audio_enabled = map_view.audible_alert_enabled()
                notifications_enabled = focus_enabled or audio_enabled
                cooldown_elapsed = False
                if notifications_enabled:
                    now_monotonic = monotonic()
                    cooldown_elapsed = (
                        last_operator_notification_at is None
                        or (now_monotonic - last_operator_notification_at) >= NOTIFICATION_COOLDOWN_SECONDS
                    )
                if focus_enabled and cooldown_elapsed:
                    map_view.present_window(
                        trigger_description=summarize_notification_triggers(
                            notification_trigger_descriptions
                        )
                    )
                if audio_enabled and cooldown_elapsed:
                    if not audio_player.play():
                        map_view.ring_bell()
                if notifications_enabled and cooldown_elapsed:
                    last_operator_notification_at = now_monotonic

            if not map_view.update():
                break
            if TEST and (
                not utils.sleep_with_ui(
                    map_view,
                    POLL_INTERVAL_SECONDS,
                    on_tick=update_attention_effects,
                )
            ):
                break
    finally:
        if fetcher is not None:
            fetcher.stop()
        audio_player.close()
        map_view.close()
        utils.set_log_time_sink(None)
        utils.finish_runtime_line()


if __name__ == "__main__":
    main()
